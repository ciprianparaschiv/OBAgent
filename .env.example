# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- Local MySQL (the imported snapshot copy; NOT production) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=studio_ro
DB_PASSWORD=studio_ro_pw
DB_NAME=studio_pms
# Text in this legacy DB may be latin1; the connector decodes accordingly.
DB_CHARSET=latin1

# --- Model: any OpenAI-compatible endpoint (provider is swappable by config) ---
# The provider is whatever OPENAI_BASE_URL points at; code never changes.
# Dev default below = Google Gemini free tier (get a key at
# https://aistudio.google.com/apikey). gemini-2.5-flash has free quota and
# supports tool-calling. For production, point these at a local open-model
# server (e.g. Ollama: http://localhost:11434/v1, key "ollama").
#
# Other OpenAI-compatible options (just change these three lines):
#   Anthropic : https://api.anthropic.com/v1/        claude-opus-4-8
#   Groq      : https://api.groq.com/openai/v1       llama-3.3-70b-versatile
#   Ollama    : http://localhost:11434/v1            qwen2.5:7b   (key: ollama)
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gemini-2.5-flash
