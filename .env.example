# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- Local MySQL (the imported snapshot copy; NOT production) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=studio_ro
DB_PASSWORD=studio_ro_pw
DB_NAME=studio_pms
# Text in this legacy DB may be latin1; the connector decodes accordingly.
DB_CHARSET=latin1

# --- Model: any OpenAI-compatible endpoint (provider is swappable by config) ---
# Dev default below points at Anthropic's OpenAI-compatible endpoint.
# For production we swap these for a local open-model server (e.g. vLLM/Ollama)
# WITHOUT changing code.
OPENAI_BASE_URL=https://api.anthropic.com/v1/
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=claude-opus-4-8
