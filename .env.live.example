# Live PRODUCTION PMS profile — READ-ONLY. Copy to .env.live (gitignored) and fill in.
# Activate by setting STUDIO_ENV_FILE=.env.live (the default profile stays the
# local snapshot in .env, so tests/dev never touch production).
#
# Connect via the SSH tunnel: run ./scripts/db_tunnel.sh in one terminal, then
#   STUDIO_ENV_FILE=.env.live studio-web

# --- DB reached through the LOCAL end of the SSH tunnel ---
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=official_OBAgent
DB_PASSWORD=REPLACE_ME
DB_NAME=official_project_new
DB_CHARSET=utf8mb4

# --- SSH tunnel (cPanel > SSH Access). Generate + AUTHORIZE a key there,
#     download the private key locally, and point SSH_KEY at it. ---
SSH_HOST=officialbranding.org
SSH_PORT=22
SSH_USER=REPLACE_ME            # your cPanel account username
SSH_KEY=~/.ssh/ob_agent_ed25519
TUNNEL_LOCAL_PORT=3307

# --- Model (same OpenAI-compatible config as dev) ---
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gemini-2.5-flash
